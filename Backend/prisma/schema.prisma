generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Company {
  id                  String              @id @default(cuid())
  parentId            String?
  name                String              @unique
  taxId               String
  logoUrl             String?
  address             String?
  phone               String?
  email               String?
  currency            String              @default("NIO")
  metadata            Json?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  accounts            Account[]
  accountingPeriods   AccountingPeriod[]
  auditLogs           AuditLog[]
  bankAccounts        BankAccount[]
  budgets             Budget[]
  closingEntries      ClosingEntry[]
  parent              Company?            @relation("CompanyHierarchy", fields: [parentId], references: [id])
  branches            Company[]           @relation("CompanyHierarchy")
  costCenters         CostCenter[]
  depreciationEntries DepreciationEntry[]
  exchangeRates       ExchangeRate[]
  fileAttachments     FileAttachment[]
  financialConcepts   FinancialConcept[]
  fixedAssets         FixedAsset[]
  invoices            Invoice[]
  journalEntries      JournalEntry[]
  notifications       Notification[]
  paymentSchedules    PaymentSchedule[]
  paymentTerms        PaymentTerm[]
  taxEntries          TaxEntry[]
  taxRates            TaxRate[]
  thirdParties        ThirdParty[]
  users               User[]
  members             UserCompany[]
}

model AccountingPeriod {
  id                  String              @id @default(cuid())
  companyId           String
  year                Int
  month               Int
  status              PeriodStatus        @default(OPEN)
  closedAt            DateTime?
  closedBy            String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  company             Company             @relation(fields: [companyId], references: [id])
  closingEntries      ClosingEntry[]
  depreciationEntries DepreciationEntry[]
  journalEntries      JournalEntry[]

  @@unique([companyId, year, month])
  @@index([companyId])
  @@index([status])
}

model Account {
  id                String             @id @default(cuid())
  companyId         String
  code              String
  name              String
  parentId          String?
  accountType       AccountType
  nature            AccountNature
  level             Int                @default(1)
  isGroup           Boolean            @default(true)
  isActive          Boolean            @default(true)
  description       String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  parent            Account?           @relation("AccountTree", fields: [parentId], references: [id])
  children          Account[]          @relation("AccountTree")
  company           Company            @relation(fields: [companyId], references: [id])
  budgets           Budget[]
  financialConcepts FinancialConcept[] @relation("ConceptAccount")
  fixedAssets       FixedAsset[]
  invoiceLines      InvoiceLine[]
  journalLines      JournalEntryLine[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([parentId])
  @@index([accountType])
}

model CostCenter {
  id                String             @id @default(cuid())
  companyId         String
  code              String
  name              String
  parentId          String?
  level             Int                @default(1)
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  budgets           Budget[]
  parent            CostCenter?        @relation("CostCenterTree", fields: [parentId], references: [id])
  children          CostCenter[]       @relation("CostCenterTree")
  company           Company            @relation(fields: [companyId], references: [id])
  financialConcepts FinancialConcept[] @relation("ConceptCostCenter")
  invoiceLines      InvoiceLine[]
  journalLines      JournalEntryLine[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([parentId])
}

model JournalEntry {
  id                  String              @id @default(cuid())
  companyId           String
  periodId            String
  entryNumber         String
  description         String
  entryDate           DateTime
  entryType           EntryType           @default(DIARIO)
  status              EntryStatus         @default(DRAFT)
  postedAt            DateTime?
  postedBy            String?
  totalDebit          Decimal             @default(0)
  totalCredit         Decimal             @default(0)
  difference          Decimal             @default(0)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  closingEntries      ClosingEntry[]
  depreciationEntries DepreciationEntry[]
  invoices            Invoice[]
  period              AccountingPeriod    @relation(fields: [periodId], references: [id])
  company             Company             @relation(fields: [companyId], references: [id])
  lines               JournalEntryLine[]
  paymentSchedules    PaymentSchedule[]

  @@unique([companyId, periodId, entryNumber])
  @@index([companyId])
  @@index([periodId])
  @@index([status])
  @@index([entryDate])
}

model JournalEntryLine {
  id             String       @id @default(cuid())
  journalEntryId String
  accountId      String
  costCenterId   String?
  description    String
  debit          Decimal      @default(0)
  credit         Decimal      @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  costCenter     CostCenter?  @relation(fields: [costCenterId], references: [id])
  account        Account      @relation(fields: [accountId], references: [id])
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  @@index([journalEntryId])
  @@index([accountId])
  @@index([costCenterId])
}

model ThirdParty {
  id           String         @id @default(cuid())
  companyId    String
  type         ThirdPartyType @default(CUSTOMER)
  taxId        String?
  name         String
  email        String?
  phone        String?
  address      String?
  city         String?
  state        String?
  country      String?
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  invoices     Invoice[]
  company      Company        @relation(fields: [companyId], references: [id])
  paymentTerms PaymentTerm[]  @relation("PaymentTermToThirdParty")

  @@index([companyId])
  @@index([type])
  @@index([taxId])
}

model PaymentTerm {
  id               String            @id @default(cuid())
  companyId        String
  code             String
  name             String
  days             Int
  description      String?
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  invoices         Invoice[]
  paymentSchedules PaymentSchedule[]
  company          Company           @relation(fields: [companyId], references: [id])
  thirdParties     ThirdParty[]      @relation("PaymentTermToThirdParty")

  @@unique([companyId, code])
  @@index([companyId])
}

model TaxRate {
  id            String     @id @default(cuid())
  companyId     String
  taxType       String
  rate          Decimal
  name          String
  description   String?
  isRetention   Boolean    @default(false)
  isActive      Boolean    @default(true)
  effectiveFrom DateTime
  effectiveTo   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  taxEntries    TaxEntry[]
  company       Company    @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([taxType])
  @@index([isActive])
}

model Invoice {
  id               String            @id @default(cuid())
  companyId        String
  thirdPartyId     String
  invoiceType      InvoiceType
  number           String
  issueDate        DateTime
  dueDate          DateTime?
  totalAmount      Decimal
  balanceDue       Decimal
  status           InvoiceStatus     @default(PENDING)
  journalEntryId   String?
  paymentTermId    String?
  subtotal         Decimal           @default(0)
  taxAmount        Decimal           @default(0)
  discountAmount   Decimal           @default(0)
  description      String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  paymentTerm      PaymentTerm?      @relation(fields: [paymentTermId], references: [id])
  journalEntry     JournalEntry?     @relation(fields: [journalEntryId], references: [id])
  thirdParty       ThirdParty        @relation(fields: [thirdPartyId], references: [id])
  company          Company           @relation(fields: [companyId], references: [id])
  lines            InvoiceLine[]
  paymentSchedules PaymentSchedule[]
  taxEntries       TaxEntry[]

  @@unique([companyId, invoiceType, number])
  @@index([companyId])
  @@index([thirdPartyId])
  @@index([status])
  @@index([dueDate])
  @@index([invoiceType])
  @@index([paymentTermId])
}

model InvoiceLine {
  id           String      @id @default(cuid())
  invoiceId    String
  lineNumber   Int
  description  String
  quantity     Decimal     @default(1)
  unitPrice    Decimal
  unit         String      @default("PIEZA")
  discountRate Decimal     @default(0)
  subtotal     Decimal
  taxBase      Decimal     @default(0)
  accountId    String?
  costCenterId String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  costCenter   CostCenter? @relation(fields: [costCenterId], references: [id])
  account      Account?    @relation(fields: [accountId], references: [id])
  invoice      Invoice     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([accountId])
}

model TaxEntry {
  id                String   @id @default(cuid())
  companyId         String
  invoiceId         String
  taxRateId         String
  taxType           String
  taxableBase       Decimal
  taxAmount         Decimal
  withholdingAmount Decimal  @default(0)
  isRetention       Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  taxRate           TaxRate  @relation(fields: [taxRateId], references: [id])
  invoice           Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  company           Company  @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([invoiceId])
  @@index([taxType])
  @@index([isRetention])
}

model PaymentSchedule {
  id                String        @id @default(cuid())
  companyId         String
  invoiceId         String
  paymentTermId     String?
  installmentNumber Int
  dueDate           DateTime
  expectedAmount    Decimal
  paidAmount        Decimal       @default(0)
  status            PaymentStatus @default(PENDING)
  paidDate          DateTime?
  journalEntryId    String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  journalEntry      JournalEntry? @relation(fields: [journalEntryId], references: [id])
  paymentTerm       PaymentTerm?  @relation(fields: [paymentTermId], references: [id])
  invoice           Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  company           Company       @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([invoiceId])
  @@index([dueDate])
  @@index([status])
}

model ClosingEntry {
  id             String           @id @default(cuid())
  companyId      String
  periodId       String
  journalEntryId String
  closingType    ClosingType
  concept        String
  totalIncome    Decimal          @default(0)
  totalExpense   Decimal          @default(0)
  netResult      Decimal          @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  journalEntry   JournalEntry     @relation(fields: [journalEntryId], references: [id])
  period         AccountingPeriod @relation(fields: [periodId], references: [id])
  company        Company          @relation(fields: [companyId], references: [id])

  @@unique([companyId, periodId, closingType])
  @@index([companyId])
  @@index([periodId])
  @@index([closingType])
}

model FinancialConcept {
  id                  String      @id @default(cuid())
  companyId           String
  code                String
  name                String
  category            String
  defaultAccountId    String?
  defaultCostCenterId String?
  isActive            Boolean     @default(true)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  costCenter          CostCenter? @relation("ConceptCostCenter", fields: [defaultCostCenterId], references: [id])
  account             Account?    @relation("ConceptAccount", fields: [defaultAccountId], references: [id])
  company             Company     @relation(fields: [companyId], references: [id])

  @@unique([companyId, code])
  @@index([companyId])
  @@index([category])
}

model BankAccount {
  id             String          @id @default(cuid())
  companyId      String
  bankName       String
  accountNumber  String
  accountType    BankAccountType @default(CHECKING)
  currency       String          @default("NIO")
  initialBalance Decimal         @default(0)
  currentBalance Decimal         @default(0)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  company        Company         @relation(fields: [companyId], references: [id])
  movements      BankMovement[]

  @@unique([companyId, accountNumber])
  @@index([companyId])
}

model BankMovement {
  id            String         @id @default(cuid())
  bankAccountId String
  movementDate  DateTime
  description   String
  reference     String?
  amount        Decimal
  movementType  MovementType
  status        MovementStatus @default(PENDING)
  journalLineId String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  bankAccount   BankAccount    @relation(fields: [bankAccountId], references: [id])

  @@index([bankAccountId])
  @@index([status])
  @@index([movementDate])
}

model User {
  id            String         @id @default(cuid())
  companyId     String?
  email         String         @unique
  name          String
  passwordHash  String
  role          UserRole       @default(ACCOUNTANT)
  metadata      Json?
  isActive      Boolean        @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  auditLogs     AuditLog[]
  notifications Notification[]
  company       Company?       @relation(fields: [companyId], references: [id])
  memberships   UserCompany[]

  @@index([companyId])
  @@index([email])
}

model UserCompany {
  id        String         @id @default(cuid())
  userId    String
  companyId String
  role      MembershipRole @default(OWNER)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  company   Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([userId])
  @@index([companyId])
}

model AuditLog {
  id          String      @id @default(cuid())
  companyId   String
  userId      String?
  action      AuditAction
  entityType  String
  entityId    String
  entityLabel String?
  oldValues   Json?
  newValues   Json?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime    @default(now())
  user        User?       @relation(fields: [userId], references: [id])
  company     Company     @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([userId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
}

model ExchangeRate {
  id           String   @id @default(cuid())
  companyId    String
  fromCurrency String
  toCurrency   String
  rate         Decimal
  date         DateTime
  source       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  company      Company  @relation(fields: [companyId], references: [id])

  @@unique([companyId, fromCurrency, toCurrency, date])
  @@index([companyId])
  @@index([date])
}

model FixedAsset {
  id                      String              @id @default(cuid())
  companyId               String
  code                    String
  name                    String
  assetType               AssetType
  purchaseDate            DateTime
  purchaseAmount          Decimal
  salvageValue            Decimal             @default(0)
  usefulLifeMonths        Int
  depreciationMethod      String              @default("STRAIGHT_LINE")
  currentBookValue        Decimal
  accumulatedDepreciation Decimal             @default(0)
  status                  AssetStatus         @default(ACTIVE)
  location                String?
  accountId               String?
  isActive                Boolean             @default(true)
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  description             String?
  depreciationEntries     DepreciationEntry[]
  account                 Account?            @relation(fields: [accountId], references: [id])
  company                 Company             @relation(fields: [companyId], references: [id])

  @@unique([companyId, code])
  @@index([companyId])
  @@index([accountId])
  @@index([status])
}

model DepreciationEntry {
  id                 String            @id @default(cuid())
  companyId          String
  fixedAssetId       String
  periodId           String?
  journalEntryId     String?
  month              Int
  year               Int
  depreciationAmount Decimal
  accumulatedTotal   Decimal
  bookValueAfter     Decimal
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  journalEntry       JournalEntry?     @relation(fields: [journalEntryId], references: [id])
  period             AccountingPeriod? @relation(fields: [periodId], references: [id])
  fixedAsset         FixedAsset        @relation(fields: [fixedAssetId], references: [id])
  company            Company           @relation(fields: [companyId], references: [id])

  @@unique([fixedAssetId, year, month])
  @@index([companyId])
  @@index([fixedAssetId])
  @@index([periodId])
  @@index([journalEntryId])
}

model Budget {
  id             String      @id @default(cuid())
  companyId      String
  year           Int
  accountId      String
  costCenterId   String?
  month          Int
  budgetedAmount Decimal
  actualAmount   Decimal     @default(0)
  variance       Decimal     @default(0)
  description    String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  costCenter     CostCenter? @relation(fields: [costCenterId], references: [id])
  account        Account     @relation(fields: [accountId], references: [id])
  company        Company     @relation(fields: [companyId], references: [id])

  @@unique([companyId, year, accountId, month, costCenterId])
  @@index([companyId])
  @@index([accountId])
  @@index([costCenterId])
  @@index([year, month])
}

model Notification {
  id         String    @id @default(cuid())
  companyId  String
  userId     String?
  type       String
  title      String
  message    String
  entityType String?
  entityId   String?
  isRead     Boolean   @default(false)
  readAt     DateTime?
  priority   Priority  @default(NORMAL)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User?     @relation(fields: [userId], references: [id])
  company    Company   @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([userId])
  @@index([isRead])
  @@index([type])
  @@index([createdAt])
}

model FileAttachment {
  id          String   @id @default(cuid())
  companyId   String
  entityType  String
  entityId    String
  fileName    String
  fileUrl     String
  fileSize    Int
  mimeType    String
  description String?
  uploadedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([entityType, entityId])
  @@index([uploadedBy])
}

enum PeriodStatus {
  OPEN
  CLOSED
  LOCKED
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

enum AccountNature {
  DEBITOR
  ACREEDOR
}

enum EntryType {
  DIARIO
  EGRESO
  INGRESO
  TRASPASO
}

enum EntryStatus {
  DRAFT
  POSTED
}

enum ThirdPartyType {
  CUSTOMER
  SUPPLIER
  BOTH
}

enum InvoiceType {
  SALE
  PURCHASE
}

enum InvoiceStatus {
  PENDING
  PARTIAL
  PAID
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

enum BankAccountType {
  CHECKING
  SAVINGS
  INVESTMENT
}

enum MovementType {
  DEBIT
  CREDIT
}

enum MovementStatus {
  RECONCILED
  PENDING
  EXCLUDED
}

enum UserRole {
  ADMIN
  ACCOUNTANT
  MANAGER
  VIEWER
}

enum MembershipRole {
  OWNER
  ADMIN
  ACCOUNTANT
  VIEWER
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  POST
  CLOSE
  LOGIN
  LOGOUT
  EXPORT
  IMPORT
}

enum AssetType {
  BUILDING
  FURNITURE
  COMPUTER
  VEHICLE
  MACHINERY
  OTHER
}

enum AssetStatus {
  ACTIVE
  DISPOSED
  SOLD
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ClosingType {
  INCOME_EXPENSE
  NET_INCOME
  PREVIOUS_YEAR
}
